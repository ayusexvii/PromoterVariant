#!/usr/bin/env python3
"""
PromoterVariant Portfolio Dashboard - Streamlit Entry Point
Engineered with state-caching algorithms to optimize cross-page loads.
"""
import streamlit as st
import pandas as pd
import numpy as np
import joblib
import plotly.express as px
import plotly.graph_objects as go
from pathlib import Path

# Enforce a sleek dark-theme workspace with widescreen constraints
st.set_page_config(
    page_title="PromoterVariant AI",
    page_icon="🧬",
    layout="wide",
    initial_sidebar_state="expanded"
)

# --- 1. MEMORY-ALIGNED CACHE ROUTINES ---
@st.cache_resource
def load_prediction_model(model_path: Path):
    """Load the machine learning estimator into permanent shared RAM."""
    if not model_path.exists():
        return None
    return joblib.load(model_path)

@st.cache_data
def load_genomic_dataframe(data_path: Path):
    """Load, clean, and pre-calculate structural values for the dataset."""
    if not data_path.exists():
        return pd.DataFrame()
    
    df = pd.read_csv(data_path, compression='gzip')
    df['abs_distance'] = df['distance_to_tss'].abs()
    
    gene_counts = df['promoter_gene'].value_counts().to_dict()
    df['gene_variant_count'] = df['promoter_gene'].map(gene_counts)
    
    if 'chrom' in df.columns:
        df['display_chrom'] = df['chrom'].astype(str).apply(lambda x: x if x.startswith('chr') else f"chr{x}")
    elif 'Chromosome' in df.columns:
        df['display_chrom'] = df['Chromosome'].astype(str).apply(lambda x: x if x.startswith('chr') else f"chr{x}")
        
    return df

# --- 2. VALIDATION STATUS FUNCTION ---
@st.cache_data
def load_validation_status():
    """Load validation status for literature genes."""
    validation_data = {
        'CHEK2': {'tissue': 'Liver', 'entries': 1, 'status': '✅ Validated', 'slope_range': '-0.446'},
        'NF2': {'tissue': 'Liver', 'entries': 1, 'status': '✅ Validated', 'slope_range': '-0.395'},
        'TERT': {'tissue': 'Brain Caudate', 'entries': 11, 'status': '✅ Validated', 'slope_range': '0.158 to 0.212'},
        'HBB': {'tissue': 'Skin', 'entries': 23, 'status': '✅ Validated', 'slope_range': '0.269 to 0.285'}
    }
    return pd.DataFrame(validation_data).T.reset_index().rename(columns={'index': 'Gene'})

# --- 3. THEME-ALIGNED CHART BUILDERS ---
def apply_neon_noir_layout(fig):
    """Inject sharp geometric styling details into active canvas layers."""
    fig.update_layout(
        template="plotly_dark",
        paper_bgcolor="rgba(11,12,16,1)",
        plot_bgcolor="rgba(26,29,36,1)",
        font_family="Monospace",
        margin=dict(l=40, r=40, t=40, b=40),
        shapes=[dict(type='rect', xref='paper', yref='paper', x0=0, y0=0, x1=1, y1=1, line=dict(color='#00F2FE', width=1))]
    )
    fig.update_xaxes(gridcolor="#2A2F35", zerolinecolor="#3A3F45")
    fig.update_yaxes(gridcolor="#2A2F35", zerolinecolor="#3A3F45")
    return fig

